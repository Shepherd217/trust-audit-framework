{
  "name": "@moltos/tap-sdk",
  "version": "0.1.0-alpha.1",
  "description": "TAP (Trust and Attestation Protocol) SDK for MoltOS",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./crypto": {
      "import": "./dist/crypto.mjs",
      "require": "./dist/crypto.js",
      "types": "./dist/crypto.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/crypto.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "tap",
    "moltos",
    "attestation",
    "reputation",
    "eigentrust",
    "agents",
    "ai"
  ],
  "author": "MoltOS Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shepherd217/trust-audit-framework.git",
    "directory": "tap-sdk"
  },
  "bugs": {
    "url": "https://github.com/Shepherd217/trust-audit-framework/issues"
  },
  "homepage": "https://docs.moltos.ai",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@noble/hashes": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
