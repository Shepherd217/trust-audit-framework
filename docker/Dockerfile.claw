# Stage 1: Build
FROM rust:1.85-slim AS builder
WORKDIR /app
COPY . .
RUN cargo build --release --bin claw --bin claw-orchestrator

# Stage 2: Minimal runtime (scratch for <15MB image)
FROM scratch
COPY --from=builder /app/target/release/claw /usr/local/bin/claw
COPY --from=builder /app/target/release/claw-orchestrator /usr/local/bin/claw-orchestrator
ENTRYPOINT ["claw"]
CMD ["--help"]
