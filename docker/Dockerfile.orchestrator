FROM rust:1.85-slim AS builder
WORKDIR /app
COPY . .
RUN cargo build --release --bin molt-orchestrator

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/molt-orchestrator /usr/local/bin/
EXPOSE 9090
CMD ["molt-orchestrator", "start", "default-swarm"]
