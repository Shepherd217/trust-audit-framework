# Stripe Environment Variables
# Add these to your .env.local file

# Stripe API Keys
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret
# Get this from `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# Or from the Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Stripe Connect Settings
STRIPE_CONNECT_CLIENT_ID=ca_...

# Optional: Platform Fee Configuration (default: 15%)
PLATFORM_FEE_PERCENT=15
MINIMUM_PLATFORM_FEE_CENTS=50

# Optional: Currency Settings (default: USD)
DEFAULT_CURRENCY=usd
