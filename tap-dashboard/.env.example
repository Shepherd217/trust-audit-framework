# =============================================================================
# MoltOS Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to git — it contains secrets!
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Supabase (Database + Auth)
# -----------------------------------------------------------------------------
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# REQUIRED: Stripe (Payments)
# -----------------------------------------------------------------------------
# Get from: Stripe Dashboard → Developers → API Keys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret for validating Stripe webhooks
# Get from: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Stripe price IDs for subscription tiers
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# -----------------------------------------------------------------------------
# OPTIONAL: Upstash Redis (Rate Limiting)
# -----------------------------------------------------------------------------
# Get from: Upstash Console → Redis → REST API
# If not set, rate limiting is disabled (fail-open)
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# -----------------------------------------------------------------------------
# OPTIONAL: Resend (Email Notifications)
# -----------------------------------------------------------------------------
# Get from: Resend Dashboard → API Keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@moltos.org

# -----------------------------------------------------------------------------
# OPTIONAL: Cloudflare Turnstile (CAPTCHA)
# -----------------------------------------------------------------------------
# Get from: Cloudflare Dashboard → Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x...
TURNSTILE_SECRET_KEY=0x...

# -----------------------------------------------------------------------------
# OPTIONAL: Monitoring & Error Tracking
# -----------------------------------------------------------------------------
# Sentry DSN for error tracking
SENTRY_DSN=https://...sentry.io/...

# Vercel Analytics (auto-enabled on Vercel)
VERCEL_ANALYTICS_ID=

# -----------------------------------------------------------------------------
# OPTIONAL: Multi-chain RPC (for oracle pricing)
# -----------------------------------------------------------------------------
# Get from: Alchemy, Infura, or QuickNode
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# -----------------------------------------------------------------------------
# OPTIONAL: AWS KMS (for enterprise key management)
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_KMS_KEY_ID=...

# -----------------------------------------------------------------------------
# OPTIONAL: Firecracker / VM Management
# -----------------------------------------------------------------------------
# Only needed if using Firecracker microVMs instead of WASM
FIRECRACKER_SOCKET_PATH=/var/run/firecracker.socket
FIRECRACKER_KERNEL_PATH=/var/lib/firecker/vmlinux
FIRECRACKER_ROOTFS_PATH=/var/lib/firecracker/rootfs.ext4

# -----------------------------------------------------------------------------
# DEVELOPMENT: Debug Flags
# -----------------------------------------------------------------------------
# Enable verbose logging
DEBUG=false

# Skip auth checks (DANGEROUS - only for local dev)
SKIP_AUTH=false

# Use mock data instead of real API calls
MOCK_DATA=false

# -----------------------------------------------------------------------------
# SECURITY: Genesis Token (for bootstrapping first agents)
# -----------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
GENESIS_TOKEN=your-secure-random-token-here
INTERNAL_DISPATCH_KEY=your-secure-random-internal-key-here

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable BLS signature verification (experimental)
ENABLE_BLS_VERIFICATION=false

# Enable honeypot auto-enforcement
ENABLE_HONEYPOT_AUTO_ENFORCE=true

# Enable appeals and recovery
ENABLE_APPEALS=true

# -----------------------------------------------------------------------------
# DEPLOYMENT
# -----------------------------------------------------------------------------
# Vercel specific (auto-set by Vercel)
VERCEL_URL=localhost:3000
VERCEL_ENV=development

# Production domain (for CORS and callbacks)
NEXT_PUBLIC_APP_URL=https://moltos.org

# =============================================================================
# Verification Checklist
# =============================================================================
# Before deploying to production, verify:
# 
# [ ] All REQUIRED variables are set
# [ ] STRIPE keys are production (pk_live_, sk_live_)
# [ ] SUPABASE_SERVICE_ROLE_KEY is service_role (not anon)
# [ ] GENESIS_TOKEN is cryptographically random
# [ ] UPSTASH_REDIS_REST_URL is set (for rate limiting)
# [ ] SENTRY_DSN is set (for error tracking)
# [ ] RESEND_API_KEY is set (for notifications)
# [ ] DEBUG and SKIP_AUTH are false or unset
# [ ] .env.local is in .gitignore
# =============================================================================
